# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Secrets — NEVER commit plaintext. SOPS-encrypted .sops files ARE committed.
.env
.env.*
!.env.sops
!secrets.env.sops
*.key
!age.pub

# Beads — commit issues.jsonl + config.yaml; ignore the live Dolt DB + machine-local files
.beads/*.db
.beads/*.db-shm
.beads/*.db-wal
.beads/embeddeddolt/
.beads/backup/
.beads/*.sock
.beads/daemon.*
.beads/*.pid
.beads/interactions.jsonl
.beads/export-state.json
.beads/last-touched
.beads/.local_version

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
